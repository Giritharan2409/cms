# MongoDB Atlas connection string used by backend/db.py
# Replace <username>, <password>, <cluster-host>, and <database>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>

# Set to "true" or "1" only in local development when you need to bypass TLS
# certificate verification (e.g. on systems with SSL handshake issues).
# NEVER enable this in production — it disables certificate validation and is
# vulnerable to MITM attacks.
# MONGODB_TLS_INSECURE=false
